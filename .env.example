# Solana
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_KEYPAIR_PATH=~/.config/solana/id.json

# ClawNet Node
CLAWNET_PORT=3402
CLAWNET_AGENT_ID=my-agent
CLAWNET_AGENT_NAME=My Agent

# OpenClaw Gateway
OPENCLAW_GATEWAY_URL=http://localhost:18789

# USDC (Devnet)
USDC_MINT=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU

# x402 Payment Protocol
FACILITATOR_URL=https://x402.org/facilitator

# Sol CLI wallet name for outbound payments (requires Sol CLI installed)
SOL_CLI_WALLET_NAME=clawnet

# Node URL (public endpoint for SKILL.md commands, e.g. https://my-agent.example.com)
CLAWNET_NODE_URL=http://localhost:3402

# Default price in USD per skill invocation (e.g. 0.01 = 1 cent)
DEFAULT_SKILL_PRICE_USD=0.01

# Relay (optional — set to connect to a shared relay instead of running a public endpoint)
CLAWNET_RELAY_URL=ws://localhost:3400

# Demo — wallet address for all demo agents (set to your Solana keypair address)
DEMO_WALLET_ADDRESS=
